pipeline {
    agent any
    stages {
        stage('Checkout Pipeline Repo') {
            steps {
                checkout scm
            }
        }
        stage('Clone Application Repository') {
            steps {
                dir('webapplication-repo') {
                    // In a real multi-repo Jenkins environment, you would clone the repo here
                    git url: 'https://github.com/your-org/webapplication-repo.git', branch: 'main'
                }
            }
        }
        stage('Clone Script Repository') {
            steps {
                dir('script-repo') {
                    // In a real multi-repo Jenkins environment, you would clone the repo here
                    git url: 'https://github.com/your-org/script-repo.git', branch: 'main'
                }
            }
        }
        stage('Build') {
            steps {
                echo 'Building Simple HTML / Node.js application...'
                // If there's an npm build step for any part of the app, it would go here
                // dir('webapplication-repo/simple-index-html') {
                //     sh 'npm install'
                // }
            }
        }
        stage('Deploy') {
            steps {
                echo 'Executing simple-index-html-script/deploy.sh...'
                sh 'bash script-repo/simple-index-html-script/deploy.sh'
            }
        }
    }
}